{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch (Edge)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/web/bin/Debug/net10.0/ShiftHub.dll",
      "args": [],
      "cwd": "${workspaceFolder}/web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "debugWithEdge",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
