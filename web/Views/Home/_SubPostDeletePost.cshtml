@model ShiftHub.Models.HomeModels

<div class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Slet post</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="form-group">
                    <label asp-for="SubPost.Name">Navn</label>
                    <input asp-for="SubPost.Name" class="form-control" readonly />
                    <span asp-validation-for="SubPost.Name" class="text-danger"></span>
                </div>
                <hr />
                <div class="form-group form-switch">
                    <input type="checkbox" asp-for="SubPost.Notification" class="form-check-input" id="NotificationId" onchange="ValidateDelete()" />&nbsp;
                    <label asp-for="SubPost.Notification">Bekræft sletning</label>
                    <span asp-validation-for="SubPost.Notification" class="text-danger"></span>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" onclick="Delete()" id="DeleteId" disabled>Slet</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Luk</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    function ValidateDelete() {
        if (document.getElementById("NotificationId").checked == true) {
            document.getElementById("DeleteId").disabled = false;
        } else {
            document.getElementById("DeleteId").disabled = true;
        }
    }
    function Delete() {
        var PlaceHolderElement = $('#PopUpPlaceholder');
        var PostGroupId = '@Html.Raw($"{Model.SubPost.Id}")';

        $.ajax({
            type: 'POST',
            url: '/Home/_SubPostDelete',
            data: { Id: PostGroupId }
        }).done(function (returned) {
            document.getElementById('Group_' + returned).remove();
            PlaceHolderElement.find('.modal').modal('hide');
        });
    }

</script>