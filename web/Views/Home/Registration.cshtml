@model ShiftHub.Models.HomeModels
@{
    /// Title
    ViewData["Title"] = "Tilmelding";

    /// Messages
    foreach (ShiftHub.Models.MessageModel.Message item in Model.Messages.aList)
    {
                    <div class="alert alert-@item.Type.ToString().ToLower() d-flex align-items-center bs-popover-start" role="alert">
                        <table width="100%">
                            <tr>
                                <td align="left" valign="middle" style="font-size: 16px;">
                                    @switch (item.Type.ToString())
                        {
                            case "Info":
                                            <i class="bi bi-info-circle"></i>
                                break;
                            case "Success":
                                            <i class="bi bi-check-circle"></i>
                                break;
                            case "Warning":
                                            <i class="bi bi-exclamation-circle"></i>
                                break;
                            case "Danger":
                                            <i class="bi bi-exclamation-diamond"></i>
                                break;
                        }
                                    @item.Content
                                </td>
                                <td align="right" valign="middle">
                                    <button type="button" id="@item.UiD" class="btn-close" data-bs-dismiss="alert" title="Luk"></button>
                                </td>
                            </tr>
                        </table>
                    </div>
    @if (item.Type.ToString() != "Danger")
        {
                        <script type="text/javascript">
                            setTimeout(function () {
                                document.getElementById('@item.UiD').click();
                            }, @item.AutoClose);
                        </script>
        }
    }
}

<div id="PopUpPlaceholder"></div>

<div>
    <input type="hidden" id="SubGroupValue" />
    <input type="hidden" id="MessageShowAllValue" value="0" />

</div>

<div class="container">
    <div class="row">
        <div class="col-3">
            <h6 class="sh-section-title"><i class="bi bi-boxes me-1"></i>Arrangementer</h6>
            <hr class="sh-form-divider" />
            <div class="d-flex flex-column gap-1">
                @foreach (System.Data.DataRow aRow in Model.Data.aTable.Rows)
                {
                    <button type="button" id="Sub_@Html.Raw($"{aRow["Id"]}")" class="btn light w-100 sh-subgroup-btn" onclick="SubGroupSelect(@Html.Raw($"{aRow["Id"]}"))" title="@Html.Raw($"{aRow["Description"]}")">
                        <span class="d-flex justify-content-between align-items-center">
                            <b>@Html.Raw($"{aRow["Name"]}")</b>
                            @if ($"{aRow["Messages"]}" != "0")
                            {
                                <span class="badge bg-danger" id="@Html.Raw($"{aRow["Id"]}")_MainMessageCount">@Html.Raw($"{aRow["Messages"]}")</span>
                            }
                        </span>
                    </button>
                }
                @if (Model.Data.aTable.Rows.Count == 0)
                {
                    <div class="text-muted text-center small py-1"><i>Ingen aktive grupper fundet</i></div>
                }
            </div>
        </div>
            </table>
        </div>
        <div class="col my-1 m-1" id="workContainerId" style="display: none;">
            <ul class="nav nav-pills nav-fill" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light active" id="tab-one" data-bs-toggle="tab" data-bs-target="#one" role="tab" aria-controls="one" aria-selected="true">
                        <span class="d-inline-flex align-items-center gap-1">Overblik <span class="badge bg-danger" id="overviewMenuId"></span></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-two" data-bs-toggle="tab" data-bs-target="#two" role="tab" aria-controls="two" aria-selected="false">
                        <span class="d-inline-flex align-items-center gap-1">Vagter <span class="badge bg-danger" id="shiftsMenuId"></span></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-three" data-bs-toggle="tab" data-bs-target="#three" role="tab" aria-controls="three" aria-selected="false">
                        <span class="d-inline-flex align-items-center gap-1">Tidsforbrug <span class="badge bg-danger" id="timeUsageMenuId"></span></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-four" data-bs-toggle="tab" data-bs-target="#four" role="tab" aria-controls="four" aria-selected="false">
                        <span class="d-inline-flex align-items-center gap-1">Beskeder <span class="badge bg-danger" id="messagesMenuId"></span></span>
                    </button>
                </li>
            </ul>
            <br />
            <div class="tab-content" id="myTabContent">
                <div id="AlertPlaceholder"></div>
                <div class="tab-pane fade show active" id="one" role="tabpanel" aria-labelledby="tab-one">
                    <!-- Overview -->
                    <div class="row mb-2 mt-1">
                        <div class="col-md-12">
                            <button type="button" class="btn lightButton sh-toolbar-btn" onclick="updateOverview()" title="Opdater">
                                <i class="bi bi-arrow-repeat sh-icon-sm"></i>
                            </button>
                        </div>
                    </div>
                    <div class="row" id="OverviewView"></div>
                    <p class="sh-section-title text-center mt-3 mb-1">Tilmeldinger</p>
                    <div class="row" id="RegistrationsView"></div>
                </div>
                <div class="tab-pane fade" id="two" role="tabpanel" aria-labelledby="tab-two">
                    <!-- Shifts -->
                    <div class="row mb-2 mt-1">
                        <div class="col">
                            <button type="button" class="btn lightButton sh-toolbar-btn" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubShiftsViewAdd", "Home", new { })" title="Tilføj bruger">
                                <i class="bi bi-person-add sh-icon-sm"></i>
                            </button>
                            <button type="button" class="btn lightButton sh-toolbar-btn" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubShiftsViewRegistrations", "Home", new { })" title="Se tilmeldinger">
                                <i class="bi bi-calendar-check sh-icon-sm"></i>
                            </button>
                            <button type="button" class="btn lightButton sh-toolbar-btn" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubShiftsViewView", "Home", new { })" title="Se en samtælling af vagter">
                                <i class="bi bi-bar-chart sh-icon-sm"></i>
                            </button>
                        </div>
                        <div class="col" align="right">
                            <input class="form-control form-control-sm sh-search" type="text" id="staffFilterId" placeholder="Søg" onkeyup="updateShifts()" />
                        </div>
                    </div>
                    <table class="table" id="StaffList">
                    </table>
                </div>
                <div class="tab-pane fade" id="three" role="tabpanel" aria-labelledby="tab-three">
                    <!-- TimeUsage -->
                    <div class="row mb-2 mt-1">
                        <div class="col">
                            <button type="button" class="btn lightButton sh-toolbar-btn" onclick="location.href='/Home/SubShiftsViewHoursExport?SubGroupId=' + document.getElementById('SubGroupValue').value" title="Export timer">
                                <i class="bi bi-database-down sh-icon-sm"></i>
                            </button>
                        </div>
                        <div class="col" align="right">
                            <input class="form-control form-control-sm sh-search" type="text" id="timeFilterId" placeholder="Søg" onkeyup="updateTimeUsage()" />
                        </div>
                    </div>
                    <table class="table" id="TimeList">
                    </table>
                </div>
                <div class="tab-pane fade" id="four" role="tabpanel" aria-labelledby="tab-four">
                    <!-- Messages -->
                    <div class="row mb-2 mt-1">
                        <div class="col">
                            <button type="button" class="btn lightButton sh-toolbar-btn" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubMessageSendMessage", "Home", new { })" title="Send besked">
                                <i class="bi bi-envelope-plus sh-icon-sm"></i>
                            </button>
                            <button type="button" class="btn lightButton sh-toolbar-btn" onclick="messageShowAll()" id="messageShowAllButton" title="Vis alle">
                                <i class="bi bi-inbox sh-icon-sm"></i>
                            </button>
                            <button type="button" class="btn lightButton sh-toolbar-btn" onclick="updateMessages()" title="Opdater">
                                <i class="bi bi-arrow-repeat sh-icon-sm"></i>
                            </button>
                        </div>
                        <div class="col" align="right">
                            <input class="form-control form-control-sm sh-search" type="text" id="messagesFilterId" placeholder="Søg" onkeyup="updateMessages()" />
                        </div>
                    </div>
                    <table class="table" id="MessagesList">
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    /* Main Functions */
    function SubGroupSelect(id) {
        var SubGroupId = document.getElementById("SubGroupValue").value;

        if (SubGroupId != "") {
            document.getElementById("Sub_" + SubGroupId).classList.remove("SubGroupSelected");
        } else {
            document.getElementById("workContainerId").style = "display: block;";
        }

        document.getElementById("Sub_" + id).classList.add("SubGroupSelected");
        document.getElementById("SubGroupValue").value = id;

        $.ajax({
            url: '/Home/_SubGroupData_Registration',
            data: { SubGroupId: id }
        }).done(function (returned) {
            var dataObj = JSON.parse(returned);

            // Overview
            if (dataObj.overview.Counter > 0) {
                document.getElementById("overviewMenuId").innerHTML = dataObj.overview.Counter;
            } else {
                document.getElementById("overviewMenuId").innerHTML = '';
            }
            updateOverview();

            // Shifts
            if (dataObj.shifts.Counter > 0) {
                document.getElementById("shiftsMenuId").innerHTML = dataObj.shifts.Counter;
            } else {
                document.getElementById("shiftsMenuId").innerHTML = '';
            }
            updateShifts();

            // TimeUsage
            if (dataObj.timeUsage.Counter > 0) {
                document.getElementById("timeUsageMenuId").innerHTML = dataObj.timeUsage.Counter;
            } else {
                document.getElementById("timeUsageMenuId").innerHTML = '';
            }
            updateTimeUsage();

            // Messages
            if (dataObj.messages.Counter > 0) {
                document.getElementById("messagesMenuId").innerHTML = dataObj.messages.Counter;
            } else {
                document.getElementById("messagesMenuId").innerHTML = '';
            }
            document.getElementById("messageShowAllButton").title = 'Vis alle';
            document.getElementById("messageShowAllButton").innerHTML = '<i class="bi bi-inbox" style="font-size: 1.2rem; color: gray;"></i>';
            document.getElementById("MessageShowAllValue").value = '0';
            updateMessages();

        });
    }

    /* Overview */
    function updateOverview() {
        var SubGroupId = document.getElementById("SubGroupValue").value;
        
        $.ajax({
            type: 'POST',
            url: "/Home/_SubOverviewViewUpdate",
            data: { SubGroupId: SubGroupId }
        }).done(function (returned) {
            var dataObj = JSON.parse(returned);
            var chartLables = [];
            var chartData = [];

            // CleenUp
            document.getElementById("OverviewView").innerHTML = '';
            document.getElementById("RegistrationsView").innerHTML = '';

            // Days Charts
            for (let i = 0; i < dataObj.Days.length; i++) {
                // Create Chart Container
                document.getElementById("OverviewView").insertAdjacentHTML('beforeend', '<div class=\"col-md-4\" style=\"padding: 0px 0px 20px 0px;\"><canvas id=\"Chart_' + i + '\"></canvas></div>');

                // Reset Loop Values
                chartLables = [];
                chartData = [];

                // Count Registrated
                let r = 0;
                for (let x = 0; x < dataObj.Days[i].Shifts.length; x++) {
                    r += dataObj.Days[i].Shifts[x].Registrations;
                }

                // Set Registrated
                chartLables[0] = 'Registreret';
                chartData[0] = r;

                // Set Chart Data
                for (let x = 0; x < dataObj.Days[i].Shifts.length; x++) {
                    chartLables[(x+1)] = dataObj.Days[i].Shifts[x].Name;

                    if ((dataObj.Days[i].Shifts[x].StaffNeeds - dataObj.Days[i].Shifts[x].Registrations) < 0) {
                        chartData[(x+1)] = 0;
                    } else {
                        chartData[(x+1)] = (dataObj.Days[i].Shifts[x].StaffNeeds - dataObj.Days[i].Shifts[x].Registrations);
                    }
                }

                // Create Chart Structyre
                new Chart("Chart_" + i, {
                    type: 'doughnut',
                    data: {
                        labels: chartLables,
                        datasets: [{
                            data: chartData,
                            backgroundColor: ['#aebfd1'],
                        }]
                    },
                    options: {
                        legend: {
                            display: false
                        },
                        elements: {
                            center: {
                                text: dataObj.Days[i].WeekDay,
                                color: 'black',
                                fontStyle: 'Helvetica',
                                sidePadding: 15
                            }
                        }
                    }
                });
            }

            // Registration Chart
            document.getElementById("RegistrationsView").insertAdjacentHTML('beforeend', '<div class=\"col\" style=\"padding: 0px 0px 20px 0px;\"><canvas id=\"RegistrationsChart\"></canvas></div>');

            // Tilmeldings Chart
            new Chart("RegistrationsChart", {
                type: 'bar',
                data: {
                    labels: dataObj.Registrations.labels,
                    datasets: [{
                        data: dataObj.Registrations.data,
                        backgroundColor: '#aebfd1',
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    legend: {
                        display: false
                    },
                    responsive: true,
                    scales: {
                        yAxes: [{
                            ticks: {
                                beginAtZero: true,
                                stepSize: 1
                            }
                        }]
                    }
                }
            });

            // Set Plugins
            Chart.pluginService.register({
                beforeDraw: function (chart) {
                    if (chart.config.options.elements.center) {
                        //Get ctx from string
                        var ctx = chart.chart.ctx;

                        //Get options from the center object in options
                        var centerConfig = chart.config.options.elements.center;
                        var fontStyle = centerConfig.fontStyle || 'Arial';
                        var txt = centerConfig.text;
                        var color = centerConfig.color || '#000';
                        var sidePadding = centerConfig.sidePadding || 20;
                        var sidePaddingCalculated = (sidePadding / 100) * (chart.innerRadius * 2)
                        //Start with a base font of 30px
                        ctx.font = "30px " + fontStyle;

                        //Get the width of the string and also the width of the element minus 10 to give it 5px side padding
                        var stringWidth = ctx.measureText(txt).width;
                        var elementWidth = (chart.innerRadius * 2) - sidePaddingCalculated;

                        // Find out how much the font can grow in width.
                        var widthRatio = elementWidth / stringWidth;
                        var newFontSize = Math.floor(30 * widthRatio);
                        var elementHeight = (chart.innerRadius * 2);

                        // Pick a new font size so it will not be larger than the height of label.
                        var fontSizeToUse = Math.min(newFontSize, elementHeight);

                        //Set font settings to draw it correctly.
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        var centerX = ((chart.chartArea.left + chart.chartArea.right) / 2);
                        var centerY = ((chart.chartArea.top + chart.chartArea.bottom) / 2);
                        ctx.font = fontSizeToUse + "px " + fontStyle;
                        ctx.fillStyle = color;

                        //Draw text in center
                        ctx.fillText(txt, centerX, centerY);
                    }
                }
            });
        });
    }

    /* Shifts */
    function updateShifts(subGroupId) {
        var filterValue = document.getElementById("staffFilterId").value;
        var SubGroupId = "";

        if (subGroupId == null) {
            SubGroupId = document.getElementById("SubGroupValue").value;
        } else {
            SubGroupId = subGroupId;
        }

        $.ajax({
            type: 'POST',
            url: "/Home/_SubShiftsViewUpdate",
            data: { SubGroupId: SubGroupId, FilterValue: filterValue }
        }).done(function (returned) {
            document.getElementById("StaffList").innerHTML = returned;
            
            var PlaceHolderElement = $('#PopUpPlaceholder');

            $('button[data-bs-toggle="staffUpdate-ajax-modal"]').click(function (event) {
                var url = $(this).data('bs-url');
                $.get(url).done(function (data) {
                    PlaceHolderElement.html(data);
                    PlaceHolderElement.find('.modal').modal('show');
                })
            })
        });
    }
    function staffRemove(subGroupId, staffId) {
        var UiD = new Date().getTime();
        const regex = new RegExp('OK');

        $.ajax({
            type: 'POST',
            url: "/Home/_SubShiftsViewRemove",
            data: { SubGroupId: subGroupId, StaffId: staffId }
        }).done(function (returned) {
            updateShifts(subGroupId);

            if (regex.test(returned) == true) {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-success d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                                "<i class=\"bi bi-check-circle\"></i>&nbsp;&nbsp;" +
                                "Fjernet" +
                            "</td>" +
                            "<td align=\"right\" valign=\"middle\">" +
                                "<button type=\"button\" id=\"" + UiD + "\" class=\"btn-close\" data-bs-dismiss=\"alert\" title=\"Luk\"></button>" +
                            "</td>" +
                        "</tr>" +
                    "</table>" +
                    "<script type=\"text/javascript\">" +
                        "setTimeout(function () {" +
                            "document.getElementById('" + UiD + "').click();" +
                        "}, 3000);" +
                    "<\/script>" +
                "</div>";
            } else {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-danger d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                    "<i class=\"bi bi-exclamation-diamond\"></i>&nbsp;&nbsp;" +
                                returned +
                            "</td>" +
                            "<td align=\"right\" valign=\"middle\">" +
                                "<button type=\"button\" id=\"" + UiD + "\" class=\"btn-close\" data-bs-dismiss=\"alert\" title=\"Luk\"></button>" +
                            "</td>" +
                        "</tr>" +
                    "</table>" +
                "</div>";
            }
        });
    }

    /* TimeUsage */
    function updateTimeUsage() {
        var SubGroupId = document.getElementById("SubGroupValue").value;
        var filterValue = document.getElementById("timeFilterId").value;

        $.ajax({
            type: 'POST',
            url: "/Home/_SubTimeUsageViewUpdate",
            data: { SubGroupId: SubGroupId, FilterValue: filterValue }
        }).done(function (returned) {
            document.getElementById("TimeList").innerHTML = returned;

            var PlaceHolderElement = $('#PopUpPlaceholder');

            $('button[data-bs-toggle="timeUpdate-ajax-modal"]').click(function (event) {
                var url = $(this).data('bs-url');
                $.get(url).done(function (data) {
                    PlaceHolderElement.html(data);
                    PlaceHolderElement.find('.modal').modal('show');
                })
            })
        });
    }

    /* Messages */
    function updateMessages() {
        var SubGroupId = document.getElementById("SubGroupValue").value;

        $.ajax({
            type: 'POST',
            url: "/Home/_SubMessagesViewUpdate",
            data: { SubGroupId: SubGroupId, Sort: document.getElementById("MessageShowAllValue").value, Filter: document.getElementById("messagesFilterId").value }
        }).done(function (returned) {
            document.getElementById("MessagesList").innerHTML = returned;

            var PlaceHolderElement = $('#PopUpPlaceholder');

            $('button[data-bs-toggle="messageView-ajax-modal"]').click(function (event) {
                var url = $(this).data('bs-url');
                $.get(url).done(function (data) {
                    PlaceHolderElement.html(data);
                    PlaceHolderElement.find('.modal').modal('show');
                })
            })
        });
    }
    function messageShowAll() {
        if (document.getElementById("MessageShowAllValue").value == '0') {
            document.getElementById("messageShowAllButton").title = 'Vis kun nye';
            document.getElementById("messageShowAllButton").innerHTML = '<i class="bi bi-inbox-fill" style="font-size: 1.2rem; color: gray;"></i>';
            document.getElementById("MessageShowAllValue").value = '1';
        } else {
            document.getElementById("messageShowAllButton").title = 'Vis alle';
            document.getElementById("messageShowAllButton").innerHTML = '<i class="bi bi-inbox" style="font-size: 1.2rem; color: gray;"></i>';
            document.getElementById("MessageShowAllValue").value = '0';
        }
        updateMessages();
    }
    function messageDelete(messageId) {
        $.ajax({
            type: 'POST',
            url: "/Home/_SubMessagesViewDelete",
            data: { MessageId: messageId }
        }).done(function (returned) {
            updateMessages();
        });
    }

</script>