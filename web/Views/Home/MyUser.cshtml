@model ShiftHub.Models.HomeModels
@{
    /// Title
    ViewData["Title"] = "Min Bruger";

    /// Messages
    foreach (ShiftHub.Models.MessageModel.Message item in Model.Messages.aList)
    {
        <div class="alert alert-@item.Type.ToString().ToLower() sh-alert" role="alert">
            <span class="sh-alert-icon">
                @switch (item.Type.ToString())
                {
                    case "Info":
                        <i class="bi bi-info-circle"></i>
                        break;
                    case "Success":
                        <i class="bi bi-check-circle"></i>
                        break;
                    case "Warning":
                        <i class="bi bi-exclamation-circle"></i>
                        break;
                    case "Danger":
                        <i class="bi bi-exclamation-diamond"></i>
                        break;
                }
            </span>
            <span class="sh-alert-body">@item.Content</span>
            <button type="button" id="@item.UiD" class="btn-close ms-auto" data-bs-dismiss="alert" title="Luk"></button>
        </div>
        @if (item.Type.ToString() != "Danger")
        {
            <script type="text/javascript">
                setTimeout(function () {
                    document.getElementById('@item.UiD').click();
                }, @item.AutoClose);
            </script>
        }
    }
}

<div id="PopUpPlaceholder"></div>

<div class="container">
    <div class="sh-page-header">
        <i class="bi bi-person-circle"></i>
        <span>Min Bruger</span>
    </div>
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="sh-form-section">
            <form action="MyUser" method="post">
                <input type="hidden" asp-for="UserDetails.UserId" />

                <div class="form-group">
                    <label asp-for="UserDetails.Username">Brugernavn</label>
                    <input asp-for="UserDetails.Username" class="form-control" readonly />
                    <span asp-validation-for="UserDetails.Username" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="UserDetails.Password">Adgangskode</label>
                    <input type="password" asp-for="UserDetails.Password" class="form-control" />
                    <span asp-validation-for="UserDetails.Password" class="text-danger"></span>
                </div>
                <hr />
                <div class="form-group">
                    <label asp-for="UserDetails.DisplayName">Fuldenavn</label>
                    <input asp-for="UserDetails.DisplayName" class="form-control" />
                    <span asp-validation-for="UserDetails.DisplayName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="UserDetails.Mail">Mail</label>
                    <input type="email" asp-for="UserDetails.Mail" class="form-control" />
                    <span asp-validation-for="UserDetails.Mail" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="UserDetails.Phone">Telefon Nr</label>
                    <input asp-for="UserDetails.Phone" class="form-control" />
                    <span asp-validation-for="UserDetails.Phone" class="text-danger"></span>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary btn-sm">Gem</button>
                </div>
            </form>
            </div>
        </div>
    </div>
</div>