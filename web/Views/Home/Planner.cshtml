    function needsRuleKeysSave() {
        var SubGroupId = document.getElementById("SubGroupValue").value;
        var keyValues = document.getElementsByClassName("needsRuleKeysValue");
        var json = '[';
        var saveValid = true;
        
        for (let i = 0; i < keyValues.length; i++) {
            // Fjern alle mellemrum for key (Ellers virker validering ikke i tilmeldingen)
            let ValueKey = document.getElementById('key_' + keyValues[i].id).value.replace(' ', '')
                .replace('0', '').replace('1', '').replace('2', '').replace('3', '').replace('4', '')
                .replace('5', '').replace('6', '').replace('7', '').replace('8', '').replace('9', '');
            document.getElementById('key_' + keyValues[i].id).value = ValueKey;

            if (document.getElementById('title_' + keyValues[i].id).value == '' || document.getElementById('key_' + keyValues[i].id).value == '') {
                saveValid = false;
            }

            json += '{\"Title\": \"' + document.getElementById('title_' + keyValues[i].id).value + '\", \"Key\": \"' + document.getElementById('key_' + keyValues[i].id).value + '\", \"Amount\": ' + document.getElementById('amount_' + keyValues[i].id).value + '}';

            if (i < (keyValues.length - 1)) {
                json += ',';
            }
        }

        json += ']';

        if (saveValid == true) {
            $.ajax({
                type: 'POST',
                url: "/Home/_SubNeedsRuleKeysSave",
                data: { SubGroupId: SubGroupId, Keys: json }
            }).done(function (returned) { });

            document.getElementById("needsRuleKeyAddButton").style = "color: black;";
            document.getElementById("needsRuleKeyAddButton").disabled = false;
        } else {
            document.getElementById("needsRuleKeyAddButton").style = "color: red;";
            document.getElementById("needsRuleKeyAddButton").disabled = true;
        }

        console.log(json);
    }
