    function formLinkRename(id) {
        var linkValue = document.getElementById("LinkValue_" + id).value;

        document.getElementById("LinkId_" + id).innerHTML = linkValue;
    }
    function formLinkChange(id, type) {
        var linkValue = document.getElementById("LinkValue_" + id).value;

        switch(type) {
            case "bootstrap":
                document.getElementById("LinkValue_" + id).disabled = false;
                document.getElementById("LinkId_" + id).classList.remove("btn");
                document.getElementById("LinkId_" + id).classList.remove("btn-success");
                document.getElementById("LinkId_" + id).classList.add("btn");
                document.getElementById("LinkId_" + id).classList.add("btn-success");
                document.getElementById("LinkId_" + id).innerHTML = linkValue;
                break;
            case "html":
                document.getElementById("LinkValue_" + id).disabled = false;
                document.getElementById("LinkId_" + id).classList.remove("btn");
                document.getElementById("LinkId_" + id).classList.remove("btn-success");
                document.getElementById("LinkId_" + id).innerHTML = linkValue;
                break;
            case "raw":
                document.getElementById("LinkValue_" + id).disabled = true;
                document.getElementById("LinkId_" + id).classList.remove("btn");
                document.getElementById("LinkId_" + id).classList.remove("btn-success");
                document.getElementById("LinkId_" + id).innerHTML = document.getElementById("LinkId_" + id).href;
                break;
        }
    }

    function formAllowDrop(ev) {
        const SourceId = document.getElementById("DragSourceId").value;
        const TargegId = ev.target.id;
        const regExList = new RegExp('ElementList');

        if (regExList.test(TargegId) == true) {
            ev.preventDefault();
