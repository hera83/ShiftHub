@model ShiftHub.Models.HomeModels
@{
    /// Title
    ViewData["Title"] = "Planlægger";

    /// Messages
    foreach (ShiftHub.Models.MessageModel.Message item in Model.Messages.aList)
    {
                                                        <div class="alert alert-@item.Type.ToString().ToLower() d-flex align-items-center bs-popover-start" role="alert">
                                                            <table width="100%">
                                                                <tr>
                                                                    <td align="left" valign="middle" style="font-size: 16px;">
                                                                        @switch (item.Type.ToString())
                        {
                            case "Info":
                                                                                <i class="bi bi-info-circle"></i>
                                break;
                            case "Success":
                                                                                <i class="bi bi-check-circle"></i>
                                break;
                            case "Warning":
                                                                                <i class="bi bi-exclamation-circle"></i>

                                break;
                            case "Danger":
                                                                                <i class="bi bi-exclamation-diamond"></i>
                                break;
                        }
                                                                          @item.Content
                                                                    </td>
                                                                    <td align="right" valign="middle">
                                                                        <button type="button" id="@item.UiD" class="btn-close" data-bs-dismiss="alert" title="Luk"></button>
                                                                    </td>
                                                                </tr>
                                                            </table>
                                                        </div>
    @if (item.Type.ToString() != "Danger")
        {
                                                            <script type="text/javascript">
                                                                setTimeout(function () {
                                                                    document.getElementById('@item.UiD').click();
                                                                }, @item.AutoClose);
                                                            </script>
        }
    }
}

<div class="show" id="PopUpPlaceholder"></div>

<div>
    <!-- Faste Variabler -->
    <input type="hidden" id="SubGroupValue" />
    <input type="hidden" id="DragSourceId" />
</div>
<div id="dataCollection">
    <!-- Dynamiske Variabler -->
</div>

<div class="container">
    <div class="row">
        <div class="col-3">
            <h5><i class="bi bi-collection"> Arrangementer</i></h5>
            <hr />
            <table border="0" width="100%">
            @foreach (System.Data.DataRow aRow in Model.Data.aTable.Rows)
            {
                <tr>
                    <td align="left" valign="middle">
                        <button type="button" id="Sub_@Html.Raw($"{aRow["Id"]}")" class="btn light" onclick="SubGroupSelect(@Html.Raw($"{aRow["Id"]}"))" style="width: 100%; text-align: left; border: 1px solid lightgray;" title="@Html.Raw($"{aRow["Description"]}")">
                            <b>@Html.Raw($"{aRow["Name"]}")</b>
                        </button>
                    </td>
                    <td align="right" valign="middle" style="width: 30px;">
                        <button type="button" class="btn lightButton" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("DeleteSubGroup", "Home", new { SubGroupId = Convert.ToInt32($"{aRow["Id"]}") })" title="Slet gruppe" @if ($"{aRow["Activated"]}" == "1" && User.IsInRole("Administrator") == false && User.IsInRole("InCharge") == false) { @Html.Raw(" disabled") }>
                            <center><i class="bi bi-trash2" style="font-size: 1.2rem; color: gray;"></i></center>
                        </button>
                    </td>
                </tr>
            }
            @if (Model.Data.aTable.Rows.Count == 0)
            {
                <tr>
                    <td align="center" valign="middle">
                        <i>Ingen grupper fundet</i>
                    </td>
                </tr>
            }
            </table>
            <button type="button" class="btn lightButton" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("AddSubGroup", "Home", new { })" title="">
                <center><i class="bi bi-patch-plus" style="font-size: 1.2rem; color: gray;"></i></center>
            </button>
        </div>
        <div class="col my-1 m-1" id="workContainerId" style="display: none;">
            <ul class="nav nav-pills nav-fill" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light active" id="tab-one" data-bs-toggle="tab" data-bs-target="#one" role="tab" aria-controls="one" aria-selected="true">Dage</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-two" data-bs-toggle="tab" data-bs-target="#two" role="tab" aria-controls="two" aria-selected="false">Vagter</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-three" data-bs-toggle="tab" data-bs-target="#three" role="tab" aria-controls="three" aria-selected="false">Behov</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-four" data-bs-toggle="tab" data-bs-target="#four" role="tab" aria-controls="four" aria-selected="false">Brugere</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link light" id="tab-five" data-bs-toggle="tab" data-bs-target="#five" role="tab" aria-controls="five" aria-selected="false">Tilmelding</button>
                </li>
            </ul>
            <br />
            <div class="tab-content" id="myTabContent">
                <div id="AlertPlaceholder"></div>
                <div class="tab-pane fade show active" id="one" role="tabpanel" aria-labelledby="tab-one">
                    <!-- Dage -->
                    <table width="100%">
                        <tr>
                            <td width="70%" valign="top">
                                <div class="row">
                                    <div class="col">
                                        <button type="button" class="btn lightButton Activated LederAct" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubDaysAdd", "Home", new { })" title="Tilføj dag(e)">
                                            <i class="bi bi-calendar-plus" style="font-size: 1.2rem; color: gray;"></i>
                                        </button>
                                    </div>
                                    <div class="col" align="right">
                                        <input class="form-control" type="text" id="daysFilterId" placeholder="Søg" onkeyup="daysUpdate()" style="width: 180px;" />
                                    </div>
                                </div>
                                <table class="table" id="DaysList">
                                </table>
                            </td>
                            <td width="30%" valign="top">
                                <div style="margin: 0px 0px 0px 15px;">
                                    <div class="card">
                                        <div class="card-header">
                                            Døgnrytme
                                        </div>
                                        <div class="card-body">
                                            <table width="100%">
                                                <tr>
                                                    <td width="49%">
                                                        <input class="form-control form-control-sm Activated" type="time" value="00:00" onchange="daysCycleUpdate('change')" id="daysCycleStartId" title="OBS: Når denne ændres slettes alle vagter og behov!" />
                                                    </td>
                                                    <td width="2%"></td>
                                                    <td width="49%">
                                                        <input class="form-control form-control-sm" type="time" value="23:59" id="daysCycleEndId" readonly />
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                    <div class="card" style="margin-top: 10px;">
                                        <div class="card-header">
                                            Noter
                                        </div>
                                        <div class="card-body">
                                            <textarea rows="12" style="width: 100%; border: none;" onkeyup="daysNoteUpdate()" id="daysNoteId"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="tab-pane fade" id="two" role="tabpanel" aria-labelledby="tab-two">
                    <!-- Vagter -->
                    <table width="100%">
                        <tr>
                            <td width="70%" valign="top">
                                <div class="row">
                                    <div class="col">
                                        <button type="button" class="btn lightButton Activated LederAct" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubShiftsAdd", "Home", new { })" title="Opret vagt">
                                            <i class="bi bi-person-badge" style="font-size: 1.2rem; color: gray;"></i>
                                        </button>
                                        <button type="button" class="btn lightButton Activated LederAct" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubShiftsView", "Home", new { })" title="Se en samtælling af vagter">
                                            <i class="bi bi-bar-chart" style="font-size: 1.2rem; color: gray;"></i>
                                        </button>
                                    </div>
                                    <div class="col" align="right">
                                        <input class="form-control" type="text" id="shiftsFilterId" placeholder="Søg" onkeyup="shiftsUpdate()" style="width: 180px;" />
                                    </div>
                                </div>
                                <table class="table" id="ShiftsList">
                                </table>
                            </td>
                            <td width="30%" valign="top">
                                <div style="margin: 0px 0px 0px 15px;">
                                    <div class="card">
                                        <div class="card-header">
                                            Noter
                                        </div>
                                        <div class="card-body">
                                            <textarea rows="12" style="width: 100%; border: none;" onkeyup="shiftsNoteUpdate()" id="shiftsNoteId"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="tab-pane fade" id="three" role="tabpanel" aria-labelledby="tab-three">
                    <!-- Behov -->
                    <table width="100%">
                        <tr>
                            <td width="70%" valign="top">
                                <div class="row">
                                    <div class="col" align="right">
                                        <input class="form-control" type="text" id="needsFilterId" placeholder="Søg" onkeyup="needsUpdate()" style="width: 180px;" />
                                    </div>
                                </div>
                                <table class="table" id="NeedsList">
                                </table>
                            </td>
                            <td width="30%" valign="top">
                                <div style="margin: 0px 0px 0px 15px;">
                                    <div class="card">
                                        <div class="card-header">
                                            Regler
                                        </div>
                                        <div class="card-body">
                                            <table border="0" width="100%">
                                                <tr>
                                                    <td align="left" valign="middle">
                                                        <u>Weekend vagt(er)</u>
                                                    </td>
                                                    <td align="right" valign="middle">
                                                        <input type="checkbox" class="form-check-input Activated LederAct" id="needsRuleWeekend_Active" onclick="needsRuleWeekend(this)" />
                                                    </td>
                                                </tr>
                                                <tr id="needsRuleWeekend_Container" style="display: none;">
                                                    <td align="left" valign="middle">
                                                        <input type="number" class="form-control form-control-sm Activated LederAct" id="needsRuleWeekend_Count" value="1" min="1" style="width: 50px; text-align: right;" onchange="needsRuleWeekendSave()" />
                                                    </td>
                                                    <td align="left" valign="middle">
                                                        &nbsp;<i>Antal dage</i>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td align="left" valign="middle">
                                                        <u>Antal timer</u>
                                                    </td>
                                                    <td align="right" valign="middle">
                                                        <input type="checkbox" class="form-check-input Activated LederAct" id="needsRuleHours_Active" onclick="needsRuleHours(this)" />
                                                    </td>
                                                </tr>
                                                <tr id="needsRuleHours_Container" style="display: none;">
                                                    <td align="left" valign="middle">
                                                        <input type="number" class="form-control form-control-sm Activated LederAct" id="needsRuleHours_Count" value="1" min="1" style="width: 50px; text-align: right;" onchange="needsRuleHoursSave()" />
                                                    </td>
                                                    <td align="left" valign="middle">
                                                        &nbsp;<i>Antal timer</i>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td align="left" valign="middle">
                                                        <u>Særlig Key</u>
                                                    </td>
                                                    <td align="right" valign="middle">
                                                        <input type="checkbox" class="form-check-input Activated LederAct" id="needsRuleKeys_Active" onclick="needsRuleKeys(this)" />
                                                    </td>
                                                </tr>
                                                <tr id="needsRuleKeys_Container" style="display: none;">
                                                    <td colspan="2" align="left" valign="middle">
                                                        <div id="needsRuleKeysView">
                                                        </div>
                                                        <table width="100%">
                                                            <tr>
                                                                <td align="center" valign="middle">
                                                                    <button type="button" class="btn Activated LederAct" onclick="needsRuleKeysAdd()" id="needsRuleKeyAddButton"><i class="bi bi-plus-circle" style="font-size: 1.3rem;"></i></button>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>

                                            </table>
                                        </div>
                                    </div>
                                    <div class="card" style="margin-top: 10px;">
                                        <div class="card-header">
                                            Noter
                                        </div>
                                        <div class="card-body">
                                            <textarea rows="12" style="width: 100%; border: none;" onkeyup="needsNoteUpdate()" id="needsNoteId"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="tab-pane fade" id="four" role="tabpanel" aria-labelledby="tab-four">
                    <!-- Brugere -->
                    <table width="100%">
                        <tr>
                            <td>
                                <div class="row">
                                    <div class="col">
                                        <button type="button" class="btn lightButton Activated LederAct" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubStaffAdd", "Home", new { })" title="Tilføj bruger">
                                            <i class="bi bi-person-add" style="font-size: 1.2rem; color: gray;"></i>
                                        </button>
                                    </div>
                                    <div class="col" align="right">
                                        <input class="form-control" type="text" id="staffFilterId" placeholder="Søg" onkeyup="staffUpdate()" style="width: 180px;" />
                                    </div>
                                </div>
                                <table class="table" id="StaffList">
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="tab-pane fade" id="five" role="tabpanel" aria-labelledby="tab-five">
                    <!-- Tilmelding -->
                    <table width="100%">
                        <tr>
                            <td id="ElementList" ondrop="formDrop(event)" ondragover="formAllowDrop(event)">
                            </td>
                        </tr>
                        <tr><td height="20px"></td></tr>
                        <tr>
                            <td align="center" valign="middle">
                                <button class="btn lightButton Activated LederAct" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("SubFormElements", "Home", new { })" title="Tilføj element">
                                    <i class="bi bi-plus-circle" style="font-size: 2rem; color: gray;"></i>
                                </button>
                                <button class="btn lightButton Activated LederAct" onclick="formSave()" title="Gem tilmelding">
                                    <i class="bi bi-floppy" style="font-size: 2rem; color: gray;"></i>
                                </button>
                                <button class="btn lightButton Activated" onclick="formActivate()" title="Aktiver & Send">
                                    <i class="bi bi-browser-chrome" style="font-size: 2rem; color: gray;"></i>
                                </button>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    /* Main Functions */
    function SubGroupSelect(id) {
        var SubGroupId = document.getElementById("SubGroupValue").value;

        if (SubGroupId != "") {
            document.getElementById("Sub_" + SubGroupId).classList.remove("SubGroupSelected");
        } else {
            document.getElementById("workContainerId").style = "display: block;";
        }

        document.getElementById("Sub_" + id).classList.add("SubGroupSelected");
        document.getElementById("SubGroupValue").value = id;

        $.ajax({
            url: '/Home/_SubGroupData_Planner',
            data: { SubGroupId: id }
        }).done(function (returned) {
            document.getElementById("dataCollection").innerHTML = returned;

            // Update Days
            daysUpdate(id);
            if (document.getElementById("SubGroup_DaysCycle").value != "") {
                document.getElementById("daysCycleStartId").value = document.getElementById("SubGroup_DaysCycle").value;
                daysCycleUpdate();
            }
            document.getElementById("daysNoteId").value = document.getElementById("SubGroup_DaysNote").value;

            // Update Shifts
            shiftsUpdate(id);
            document.getElementById("shiftsNoteId").value = document.getElementById("SubGroup_ShiftsNote").value;

            // Update Needs
            needsUpdate(id);
            if (document.getElementById("SubGroup_NeedsRuleWeekend").value != "") {
                document.getElementById("needsRuleWeekend_Active").checked = true;
                document.getElementById("needsRuleWeekend_Container").style = "display: block;";
                document.getElementById("needsRuleWeekend_Count").value = document.getElementById("SubGroup_NeedsRuleWeekend").value;
            } else {
                document.getElementById("needsRuleWeekend_Active").checked = false;
                document.getElementById("needsRuleWeekend_Container").style = "display: none;";
                document.getElementById("needsRuleWeekend_Count").value = "1";
            }

            if (document.getElementById("SubGroup_NeedsRuleHours").value != "") {
                document.getElementById("needsRuleHours_Active").checked = true;
                document.getElementById("needsRuleHours_Container").style = "display: block;";
                document.getElementById("needsRuleHours_Count").value = document.getElementById("SubGroup_NeedsRuleHours").value;
            } else {
                document.getElementById("needsRuleHours_Active").checked = false;
                document.getElementById("needsRuleHours_Container").style = "display: none;";
                document.getElementById("needsRuleHours_Count").value = "1";
            }

            if (document.getElementById("SubGroup_NeedsRuleKeys").innerHTML != "") {
                document.getElementById("needsRuleKeys_Active").checked = true;
                document.getElementById("needsRuleKeys_Container").style = "display: block;";
                needsRuleKeysUpdate();
            } else {
                document.getElementById("needsRuleKeys_Active").checked = false;
                document.getElementById("needsRuleKeys_Container").style = "display: none;";
                document.getElementById("needsRuleKeysView").innerHTML = '';
            }

            document.getElementById("needsNoteId").value = document.getElementById("SubGroup_NeedsNote").value;

            // Update Staff
            staffUpdate(id);

            // Update Tilmelding
            document.getElementById("ElementList").innerHTML = document.getElementById("SubGroup_Form").innerHTML;
            document.getElementById("SubGroup_Form").innerHTML = ""; // Husk at nulstil ellers kommer den to gange!

            // Deaktiver funktioner som ikke skal være tilgængelig når subgruppen aktiveres
            lockDown();
        });
    }

    /* Dage (Days) */
    function daysUpdate(subGroupId) {
        var filterValue = document.getElementById("daysFilterId").value;
        var SubGroupId = "";

        if (subGroupId == null) {
            SubGroupId = document.getElementById("SubGroupValue").value;
        } else {
            SubGroupId = subGroupId;
        }

        $.ajax({
            type: 'POST',
            url: "/Home/_SubDaysUpdate",
            data: { SubGroupId: SubGroupId, FilterValue: filterValue }
        }).done(function (returned) {
            document.getElementById("DaysList").innerHTML = returned;
            
            lockDown();

            var PlaceHolderElement = $('#PopUpPlaceholder');

            $('button[data-bs-toggle="daysUpdate-ajax-modal"]').click(function (event) {
                var url = $(this).data('bs-url');
                $.get(url).done(function (data) {
                    PlaceHolderElement.html(data);
                    PlaceHolderElement.find('.modal').modal('show');
                })
            })
        });
    }
    function daysRemove(subGroupId, daysId) {
        var UiD = new Date().getTime();
        const regex = new RegExp('OK');

        $.ajax({
            type: 'POST',
            url: "/Home/_SubDaysRemove",
            data: { SubGroupId: subGroupId, DaysId: daysId }
        }).done(function (returned) {
            daysUpdate(subGroupId);
            shiftsUpdate(subGroupId);
            needsUpdate(subGroupId);

            if (regex.test(returned) == true) {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-success d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                                "<i class=\"bi bi-check-circle\"></i>&nbsp;&nbsp;" +
                                "Slettet" +
                            "</td>" +
                            "<td align=\"right\" valign=\"middle\">" +
                                "<button type=\"button\" id=\"" + UiD + "\" class=\"btn-close\" data-bs-dismiss=\"alert\" title=\"Luk\"></button>" +
                            "</td>" +
                        "</tr>" +
                    "</table>" +
                    "<script type=\"text/javascript\">" +
                        "setTimeout(function () {" +
                            "document.getElementById('" + UiD + "').click();" +
                        "}, 3000);" +
                    "<\/script>" +
                "</div>";
            } else {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-danger d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                    "<i class=\"bi bi-exclamation-diamond\"></i>&nbsp;&nbsp;" +
                                returned +
                            "</td>" +
                            "<td align=\"right\" valign=\"middle\">" +
                                "<button type=\"button\" id=\"" + UiD + "\" class=\"btn-close\" data-bs-dismiss=\"alert\" title=\"Luk\"></button>" +
                            "</td>" +
                        "</tr>" +
                    "</table>" +
                "</div>";
            }
        });
    }
    function daysCycleUpdate(type) {
        var subGroupId = document.getElementById("SubGroupValue").value;

        if (type == 'change') {
            $.ajax({
                type: 'POST',
                url: "/Home/_KeyValueSave",
                data: { SubGroupId: subGroupId, KeyName: "DaysCycle", KeyValue: document.getElementById("daysCycleStartId").value }
            }).done(function (returned) {});

            $.ajax({
                type: 'POST',
                url: "/Home/_DaysCycleCleenUp",
                data: { SubGroupId: subGroupId }
            }).done(function (returned) {
                shiftsUpdate(subGroupId);
                needsUpdate(subGroupId);
            });
        }

        $.ajax({
            type: 'POST',
            url: "/Home/_DaysCycleUpdate",
            data: { DaysCycleStart: document.getElementById("daysCycleStartId").value }
        }).done(function (returned) {
            document.getElementById("daysCycleEndId").value = returned;
        });
    }
    function daysNoteUpdate() {
        var subGroupId = document.getElementById("SubGroupValue").value;

        $.ajax({
            type: 'POST',
            url: "/Home/_KeyValueSave",
            data: { SubGroupId: subGroupId, KeyName: "DaysNote", KeyValue: document.getElementById("daysNoteId").value }
        }).done(function (returned) { });
    }

    /* Vagter (Shifts) */
    function shiftsUpdate(subGroupId) {
        var filterValue = document.getElementById("shiftsFilterId").value;
        var SubGroupId = "";

        if (subGroupId == null) {
            SubGroupId = document.getElementById("SubGroupValue").value;
        } else {
            SubGroupId = subGroupId;
        }

        $.ajax({
            type: 'POST',
            url: "/Home/_SubShiftsUpdate",
            data: { SubGroupId: SubGroupId, FilterValue: filterValue }
        }).done(function (returned) {
            document.getElementById("ShiftsList").innerHTML = returned;

            lockDown();

            var PlaceHolderElement = $('#PopUpPlaceholder');

            $('button[data-bs-toggle="shiftsUpdate-ajax-modal"]').click(function (event) {
                var url = $(this).data('bs-url');
                $.get(url).done(function (data) {
                    PlaceHolderElement.html(data);
                    PlaceHolderElement.find('.modal').modal('show');
                })
            })
        });
    }
    function shiftsRemove(subGroupId, shiftsId) {
        var UiD = new Date().getTime();
        const regex = new RegExp('OK');

        $.ajax({
            type: 'POST',
            url: "/Home/_SubShiftsRemove",
            data: { SubGroupId: subGroupId, ShiftsId: shiftsId }
        }).done(function (returned) {
            shiftsUpdate(subGroupId);
            needsUpdate(subGroupId);

            if (regex.test(returned) == true) {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-success d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                                "<i class=\"bi bi-check-circle\"></i>&nbsp;&nbsp;" +
                                "Slettet" +
                            "</td>" +
                            "<td align=\"right\" valign=\"middle\">" +
                                "<button type=\"button\" id=\"" + UiD + "\" class=\"btn-close\" data-bs-dismiss=\"alert\" title=\"Luk\"></button>" +
                            "</td>" +
                        "</tr>" +
                    "</table>" +
                    "<script type=\"text/javascript\">" +
                        "setTimeout(function () {" +
                            "document.getElementById('" + UiD + "').click();" +
                        "}, 3000);" +
                    "<\/script>" +
                "</div>";
            } else {
                document.getElementById("AlertPlaceholder").innerHTML = "<div class=\"alert alert-danger d-flex align-items-center bs-popover-start\" role=\"alert\">" +
                    "<table width=\"100%\">" +
                        "<tr>" +
                            "<td align=\"left\" valign=\"middle\" style=\"font-size: 16px;\">" +
                    "<i class=\"bi bi-exclamation-diamond\"></i>&nbsp;&nbsp;" +
                                returned +
                            "</td>" +
