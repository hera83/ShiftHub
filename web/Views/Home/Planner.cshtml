    function formDrag(ev) {
        for (var i = 0; i < document.getElementsByTagName("textarea").length; i++) {
            document.getElementsByTagName("textarea")[i].readOnly = true;
        }

        ev.dataTransfer.setData("text", ev.target.id);
        document.getElementById("DragSourceId").value = ev.dataTransfer.getData("text");
    }
    function formDragend() {
        for (var i = 0; i < document.getElementsByTagName("textarea").length; i++) {
            document.getElementsByTagName("textarea")[i].readOnly = false;
        }
    }
    function formDrop(ev) {
        ev.preventDefault();
        var data = ev.dataTransfer.getData("text");
        ev.target.appendChild(document.getElementById(data));
    }

