@model ShiftHub.Models.HomeModels

<div class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Advarsel</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <table width="100%">
                    <tr>
                        <td align="left" valign="top">
                            <font style="font-size: 16px; font-weight: 600;">Bruger er <u>ikke</u> mødt til sin vagt?</font>
                            <hr />
                            <b>@Html.Raw($"{Model.Data.aTable.Rows[0]["Name"]}")</b><br />
                            <i>@Html.Raw($"{Model.Data.aTable.Rows[0]["Mail"]}")</i><br />
                            <i>@Html.Raw($"{Model.Data.aTable.Rows[0]["Phone"]}")</i><br />
                            <hr />
                            <i>Vagt overskredet med: 
                                
                                @if (Convert.ToInt32($"{Convert.ToString($"{Model.Data.bTable.Rows[0]["Min"]}").Replace("-", "")}") < 60)
                                {
                                    @Html.Raw(Convert.ToString($"{Model.Data.bTable.Rows[0]["Min"]}").Replace("-", "") + " Minutter")
                                }
                                else
                                {
                                    @Html.Raw($"{(Convert.ToInt32($"{Convert.ToString($"{Model.Data.bTable.Rows[0]["Min"]}").Replace("-", "")}") / 60)} Timer {(Convert.ToInt32($"{Convert.ToString($"{Model.Data.bTable.Rows[0]["Min"]}").Replace("-", "")}") - ((Convert.ToInt32($"{Convert.ToString($"{Model.Data.bTable.Rows[0]["Min"]}").Replace("-", "")}") / 60) * 60))} Min.")
                                }
                            </i><br />
                        </td>
                        <td align="center" valign="top" width="20px">
                            <div style="min-height: 200px; border-left: 1px solid lightgray; margin-left: 10px;"></div>
                        </td>
                        <td align="left" valign="top" width="150px">
                            <button type="button" class="btn btn-outline-dark" onclick="StaffSnooz(15)" style="width: 100%; margin-bottom: 8px;">
                                Udskyd 15 Min
                            </button>
                            <button type="button" class="btn btn-outline-dark" onclick="StaffSnooz(30)" style="width: 100%; margin-bottom: 8px;">
                                Udskyd 30 Min
                            </button>
                            <button type="button" class="btn btn-outline-dark" onclick="StaffSnooz(60)" style="width: 100%; margin-bottom: 8px;">
                                Udskyd 60 Min
                            </button>
                            <button type="button" class="btn btn-outline-danger" onclick="StaffAbsent()" style="width: 100%;">
                                Udeblevet
                            </button>
                        </td>
                    </tr>
                </table>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Luk</button>
            </div>
        </div>
    </div>
</div>
<script type="text/javascript">
    function StaffSnooz(min) {
        var PlaceHolderElement = $('#PopUpPlaceholder');
        var subGroupId = document.getElementById("SubGroupValue").value;

        $.ajax({
            type: 'POST',
            url: "/Home/_AlertSnooz",
            data: { SubGroupId: subGroupId, ShiftId: @Html.Raw($"{Model.Data.bTable.Rows[0]["Id"]}"), StaffId: @Html.Raw($"{Model.Data.aTable.Rows[0]["Id"]}"), Min: min }
        }).done(function (returned) {
            PlaceHolderElement.find('.modal').modal('hide');

            updateStaffs('once');
        });
    }
    function StaffAbsent() {
        var PlaceHolderElement = $('#PopUpPlaceholder');
        var subGroupId = document.getElementById("SubGroupValue").value;

        $.ajax({
            type: 'POST',
            url: "/Home/_AlertAbsent",
            data: { SubGroupId: subGroupId, ShiftId: @Html.Raw($"{Model.Data.bTable.Rows[0]["Id"]}"), StaffId: @Html.Raw($"{Model.Data.aTable.Rows[0]["Id"]}") }
        }).done(function (returned) {
            PlaceHolderElement.find('.modal').modal('hide');

            updateStaffs('once');
        });
    }

</script>