@model ShiftHub.Models.AdminModels
@{
    /// Title
    ViewData["Title"] = "Adm. Brugere";

    /// Messages
    foreach (ShiftHub.Models.MessageModel.Message item in Model.Messages.aList)
    {
        <div class="alert alert-@item.Type.ToString().ToLower() sh-alert" role="alert">
            <span class="sh-alert-icon">
                @switch (item.Type.ToString())
                {
                    case "Info":
                        <i class="bi bi-info-circle"></i>
                        break;
                    case "Success":
                        <i class="bi bi-check-circle"></i>
                        break;
                    case "Warning":
                        <i class="bi bi-exclamation-circle"></i>
                        break;
                    case "Danger":
                        <i class="bi bi-exclamation-diamond"></i>
                        break;
                }
            </span>
            <span class="sh-alert-body">@item.Content</span>
            <button type="button" id="@item.UiD" class="btn-close ms-auto" data-bs-dismiss="alert" title="Luk"></button>
        </div>
        @if (item.Type.ToString() != "Danger")
        {
            <script type="text/javascript">
                setTimeout(function () {
                    document.getElementById('@item.UiD').click();
                }, @item.AutoClose);
            </script>
        }
    }
}

<div id="PopUpPlaceholder"></div>

<div class="container">
    <div class="sh-page-header">
        <i class="bi bi-people"></i>
        <span>Brugere</span>
    </div>
    <div class="sh-action-bar">
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("AddUser", "Admin", new { })" title="">
            <i class="bi bi-person-plus me-1"></i>Opret bruger
        </button>
    </div>
    <link href="~/css/jquery.dataTables.min.css" rel="stylesheet" />
    <div class="sh-table-wrapper">
        <table id="UserTable">
            <thead>
                <tr>
                    <th>Gruppe</th>
                    <th>Brugernavn</th>
                    <th>Fuldenavn</th>
                    <th>Mail</th>
                    <th>Telefon</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (System.Data.DataRow aRow in Model.Data.aTable.Rows)
            {
                <tr>
                    <td>
                        @Html.Raw($"{aRow["GroupName"]}")
                    </td>
                    <td>
                        @Html.Raw($"{aRow["Username"]}")
                    </td>
                    <td>
                        @Html.Raw($"{aRow["DisplayName"]}")
                    </td>
                    <td>
                        @Html.Raw($"{aRow["Mail"]}")
                    </td>
                    <td>
                        @Html.Raw($"{aRow["Phone"]}")
                    </td>
                    <td class="sh-row-menu-cell">
                        @if (Convert.ToInt32($"{aRow["Id"]}") != Model.UserDetails.UserId)
                        {
                            if ($"{aRow["Id"]}" == "1")
                            {
                                <i>Root User</i>
                            }
                            else
                            {
                                <div class="dropdown sh-row-menu">
                                    <button type="button" class="btn sh-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end sh-row-menu-list">
                                        <li>
                                            <button type="button" class="dropdown-item" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("EditUser", "Admin", new { UserId = Convert.ToInt32(aRow["Id"]) })">
                                                <i class="bi bi-pencil me-2"></i>Rediger
                                            </button>
                                        </li>
                                        <li>
                                            <button type="button" class="dropdown-item sh-row-menu-danger" data-bs-toggle="ajax-modal" data-bs-url="@Url.Action("DeleteUser", "Admin", new { UserId = Convert.ToInt32(aRow["Id"]) })">
                                                <i class="bi bi-trash me-2"></i>Slet
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            }
                        }
                        else
                        {
                            <i>Din Bruger</i>
                        }
                    </td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>

@section Scripts{
    <script src="~/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#UserTable').DataTable({
                stateSave: true,
                fixedHeader: true,
                "ordering": false
            });
        });
    </script>
}