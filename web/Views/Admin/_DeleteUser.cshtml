@model ShiftHub.Models.AdminModels

<div class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Slet Bruger</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form action="DeleteUser" method="post">
                    <input type="hidden" asp-for="User.UserId" />
                    <input type="hidden" asp-for="User.GroupId" />

                    <div class="form-group">
                        <label asp-for="User.DisplayName">Navn</label>
                        <input asp-for="User.DisplayName" class="form-control" readonly />
                        <span asp-validation-for="User.DisplayName" class="text-danger"></span>
                    </div>
                    <hr />
                    <div class="form-group form-switch">
                        <input type="checkbox" asp-for="User.Notification" class="form-check-input" id="NotificationId" />&nbsp;
                        <label asp-for="User.Notification">Bekræft sletning</label>
                        <span asp-validation-for="User.Notification" class="text-danger"></span>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger btn-primary" data-bs-save="modal" id="DeleteId" disabled>Slet</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Luk</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    document.getElementById("NotificationId").onchange = function () { DeleteFunction() }

    function DeleteFunction() {
        var DeleteValue = document.getElementById("NotificationId").checked;

        if (DeleteValue == true) {
            document.getElementById("DeleteId").disabled = false;
        } else {
            document.getElementById("DeleteId").disabled = true;
        }
    }

</script>